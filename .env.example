# Donor compute requires no environment variables. The researcher-proposal backend
# (Vercel serverless functions in /api) needs these in production:

# Neon Postgres connection string. Provisioned automatically by Vercel's native
# Neon integration (Storage -> Create Database -> Neon), which injects this var.
DATABASE_URL=

# Reviewer console (#admin) authenticates with Google Sign-In; the API verifies the
# Google ID token and checks the email against an allowlist. Both have safe defaults
# baked into api/_auth.ts, so these are optional overrides:
#   GOOGLE_CLIENT_ID — the OAuth Web client ID (public). Must be a "Web application"
#     client with https://compute-commons.rishib.com as an authorized JS origin.
#   ADMIN_EMAILS — comma-separated allowlist of reviewer emails.
GOOGLE_CLIENT_ID=
ADMIN_EMAILS=
