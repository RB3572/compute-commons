# Donor compute requires no environment variables. The researcher-proposal backend
# (Vercel serverless functions in /api) needs these in production:

# Neon Postgres connection string. Provisioned automatically by Vercel's native
# Neon integration (Storage -> Create Database -> Neon), which injects this var.
DATABASE_URL=

# Shared secret gating the reviewer console (GET/PATCH /api/proposals and #admin).
# Set to a long random string in the Vercel project's environment variables.
ADMIN_TOKEN=
